{
    "name": "datainpane",
    "private": true,
    "version": "0.0.0",
    "engines": {
        "node": ">=20.0.0",
        "npm": ">=10.0.0"
    },
    "scripts": {
        "build:base": "NODE_ENV=production vite build --config base/vite.config.ts",
        "build:report": "NODE_ENV=production node --max_old_space_size=16384 node_modules/.bin/vite build --config report/vite.config.ts",
        "build:template-components": "NODE_ENV=production node --max_old_space_size=16384 node_modules/.bin/vite build --config template-components/vite.config.ts",
        "dev:template-components": "NODE_ENV=development node --max_old_space_size=16384 node_modules/.bin/vite build --watch --mode development --config template-components/vite.config.ts",
        "build": "npm run build:base && npm run build:report && npm run build:template-components",
        "dev:report": "NODE_ENV=development vite build --mode development --config base/vite.config.ts && NODE_ENV=development vite build --watch --mode development --config report/vite.config.ts",
        "test:public": "node_modules/.bin/cypress run --spec \"cypress/e2e/public/*\"",
        "test:org": "node_modules/.bin/cypress run --spec \"cypress/e2e/org/*\"",
        "test:open": "node_modules/.bin/cypress open --browser electron",
        "test:unit": "vitest --config ./report/vite.config.ts",
        "typecheck": "vue-tsc --noEmit"
    },
    "dependencies": {
        "@bokeh/bokehjs": "^3.0.0",
        "@formkit/themes": "^1.0.0",
        "@formkit/vue": "^1.0.0",
        "@heroicons/vue": "^2.0.15",
        "@highlightjs/vue-plugin": "^2.1.0",
        "@revolist/revogrid": "3.0.98",
        "@stencil/core": "^2.14.0",
        "alasql": "^3.0.0",
        "apache-arrow": "^18.0.0",
        "axios": "^1.1.3",
        "axios-retry": "^3.4.0",
        "chroma-js": "^2.4.2",
        "clipboard": "^2.0.10",
        "codemirror": "^5.65.6",
        "downloadjs": "^1.4.7",
        "emitter-component": "^1.1.1",
        "file-saver": "^2.0.5",
        "he": "^1.2.0",
        "highlight.js": "^11.6.0",
        "htmx.org": "^1.8.6",
        "iframe-resizer": "^4.3.2",
        "katex": "^0.16.3",
        "marked": "^14.0.0",
        "marked-highlight": "^2.0.0",
        "numeral": "^2.0.6",
        "pinia": "^2.0.24",
        "plotly.js-dist-min": "^2.16.1",
        "ramda": "^0.28.0",
        "sanitize-html": "^2.7.3",
        "sass": "^1.56.1",
        "url-join": "^5.0.0",
        "uuid": "^9.0.0",
        "vega": "^5.22.0",
        "vega-embed": "^6.20.8",
        "vega-lite": "^5.14.1",
        "vue": "^3.2.45",
        "vue-multiselect": "^3.0.0",
        "xml-js": "^1.6.11"
    },
    "devDependencies": {
        "@tailwindcss/aspect-ratio": "^0.4.2",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/typography": "^0.5.8",
        "@types/chroma-js": "^2.1.4",
        "@types/codemirror": "^5.60.5",
        "@types/downloadjs": "^1.4.3",
        "@types/file-saver": "^2.0.5",
        "@types/he": "^1.1.2",
        "@types/iframe-resizer": "^3.5.9",
        "@types/katex": "^0.14.0",
        "@types/node": "^18.11.9",
        "@types/numeral": "^2.0.2",
        "@types/ramda": "^0.28.20",
        "@types/sanitize-html": "^2.6.2",
        "@types/uuid": "^8.3.4",
        "@typescript-eslint/eslint-plugin": "^5.42.1",
        "@vitejs/plugin-vue": "^5.0.0",
        "autoprefixer": "^10.4.2",
        "cypress": "^11.0.1",
        "cypress-file-upload": "^5.0.8",
        "esbuild": "^0.15.3",
        "eslint-plugin-vue": "^9.7.0",
        "jsdom": "^21.1.0",
        "msw": "^2.0.0",
        "postcss": "^8.4.7",
        "rollup-plugin-copy": "^3.4.0",
        "tailwindcss": "^3.2.3",
        "terser": "^5.15.1",
        "typescript": "^5.0.0",
        "vite": "^6.0.0",
        "vitest": "^3.0.0",
        "vue-eslint-parser": "^9.1.0",
        "vue-tsc": "^2.0.0"
    }
}
